	partition Calendar = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS(
				    CALENDAR(DATE(2020, 7, 1), DATE(2026, 6, 30)),
				    "Year",                YEAR([Date]),
				    "Month Number",        MONTH([Date]),
				    "Month Name",          FORMAT([Date], "MMMM"),
				    "Month Short",         FORMAT([Date], "MMM"),
				    "Quarter",             "Q" & FORMAT([Date], "Q"),
				    "Season Label",        
				        SWITCH(
				            TRUE(),
				            [Date] >= DATE(2020,7,1) && [Date] <= DATE(2021,6,30), "2020-21",
				            [Date] >= DATE(2021,7,1) && [Date] <= DATE(2022,6,30), "2021-22",
				            [Date] >= DATE(2022,7,1) && [Date] <= DATE(2023,6,30), "2022-23",
				            [Date] >= DATE(2023,7,1) && [Date] <= DATE(2024,6,30), "2023-24",
				            [Date] >= DATE(2024,7,1) && [Date] <= DATE(2025,6,30), "2024-25",
				            [Date] >= DATE(2025,7,1) && [Date] <= DATE(2026,6,30), "2025-26",
				            "Unknown"
				        ),
				    "Day of Week",         FORMAT([Date], "dddd"),
				    "Day Number",          WEEKDAY([Date], 2),
				    "Is Weekend",          IF(WEEKDAY([Date], 2) >= 6, TRUE(), FALSE()),
				    "Week Number",         WEEKNUM([Date])
				)
				```

	annotation PBI_Id = 2b9e154350e7416990a8609e6f03f8a4

