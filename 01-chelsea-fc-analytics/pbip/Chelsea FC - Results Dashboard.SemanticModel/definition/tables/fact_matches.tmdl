	column opponent_strength_tier =
			
			SWITCH(
			    TRUE(),
			    ISBLANK(fact_matches[opponent_pl_finish]), "Cup / Unknown",
			    fact_matches[opponent_pl_finish] <= 6, "Top-6",
			    fact_matches[opponent_pl_finish] <= 12, "Mid-table",
			    "Bottom half"
			)
		lineageTag: 25f9a9f1-8757-4369-88fd-e25813bb3c7c
		summarizeBy: none
		sortByColumn: opponent_strength_sort

		annotation SummarizationSetBy = Automatic

	column opponent_strength_sort =
			
			SWITCH(
			    TRUE(),
			    ISBLANK(fact_matches[opponent_pl_finish]), 4,
			    fact_matches[opponent_pl_finish] <= 6, 1,
			    fact_matches[opponent_pl_finish] <= 12, 2,
			    3
			)
		dataType: int64
		formatString: 0
		lineageTag: 3b6cda90-f01c-453a-9ff2-f9bcfd5b6ee7
