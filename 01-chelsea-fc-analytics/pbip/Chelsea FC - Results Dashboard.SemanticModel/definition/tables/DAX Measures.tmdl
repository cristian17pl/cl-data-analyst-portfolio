	measure '$ Value vs Fee Ratio' =
			
			// Ratio: if > 1 the player is worth more than paid, if < 1 overpaid //
			DIVIDE(
			    CALCULATE(SUM(fact_player_valuations[market_value_gbp])),
			    CALCULATE(
			        SUM(fact_transfers[transfer_fee_gbp]),
			        fact_transfers[direction] = "IN",
			        fact_transfers[loan] = FALSE()
			    ),
			    0
			)
		displayFolder: 5_Squad_Value\$
