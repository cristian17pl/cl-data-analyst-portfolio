	measure '% Revenue YoY Growth' =
			
			VAR CurrentRevenue = [$ Total Revenue (£)]
			VAR PreviousRevenue =
			    CALCULATE(
			        [$ Total Revenue (£)],
			        PREVIOUSYEAR(Calendar[Date])
			    )
			RETURN
			    DIVIDE(CurrentRevenue - PreviousRevenue, PreviousRevenue, 0)
		displayFolder: 2_Financials\%\£
		lineageTag: c5477e77-e093-4487-b717-72063ffd67d9

		annotation PBI_FormatHint = {"isGeneralNumber":true}

