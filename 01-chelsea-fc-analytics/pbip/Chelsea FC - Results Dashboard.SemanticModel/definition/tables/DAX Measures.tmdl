	measure '# PL Points' =
			
			// Premier League is C1 //
			CALCULATE(
			    SUMX(
			        fact_matches,
			        SWITCH(fact_matches[result],
			            "W", 3,
			            "D", 1,
			            0
			        )
			    ),
			    fact_matches[competition_id] = "C1"
			)
