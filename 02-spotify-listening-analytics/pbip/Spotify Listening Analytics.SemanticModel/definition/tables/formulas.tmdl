			        & "width:100%;height:100%;box-sizing:border-box;"
			        & "display:flex;flex-direction:column;justify-content:space-between;'>"
			    & "<div style='font-size:10px;font-weight:600;color:#5c6370;"
			        & "letter-spacing:.04em;'>"
			        & "Unique Tracks</div>"
			    & "<div style='font-size:25px;font-weight:600;color:#f1f1f1;"
			        & "line-height:1.1;'>" & _TotalFmt & "</div>"
			    & "<div style='display:flex;align-items:center;gap:8px;justify-content:flex-end;'>"
			        & "<span style='background:"   & _BgColor
			            & ";border:1px solid "     & _Border
			            & ";color:"                & _Color
			            & ";font-size:11px;font-weight:600;white-space:nowrap;"
			            & "padding:2px 8px;border-radius:99px;'>"
			            & _Arrow & " " & _GrowthFmt
			        & "</span>"
			        & "<span style='font-size:11px;color:#5c6370;'>"
			            & "vs PY: " & _PYFmt
			        & "</span>"
			    & "</div>"
			& "</div>"
			```
		displayFolder: 7_Custom_Visuals
		lineageTag: 589bcc47-31bc-45ab-953d-bead3b97ae21

	measure 'REF Top Album' =
			
			VAR TopAlbum =
			    TOPN(
			        1,
			        ADDCOLUMNS(
			            VALUES(dim_song_artist[master_metadata_album_album_name]),
			            "@Album",   CALCULATE(SELECTEDVALUE(dim_song_artist[master_metadata_album_album_name])),
			            "@Artist",  CALCULATE(FIRSTNONBLANK(dim_song_artist[master_metadata_album_artist_name], 1)),
			            "@Streams", [# Streams],
			            "@Hours",   [# Total Hours Played]
			        ),
			        [@Streams], DESC,
			        [@Hours],   DESC,
			        [@Album],   ASC
			    )
			RETURN
			    CONCATENATEX(TopAlbum, [@Album] & " - " & [@Artist], ", ")
		displayFolder: 6_Text Cards
		lineageTag: a5ca52c8-ef9b-4767-a1e9-4b670d56c10c

	measure 'VIS HTML TOP Highlights' =
			
			VAR _Artist = IF(ISBLANK([REF Top Artist]),         "—", [REF Top Artist])
			VAR _Track   = IF(ISBLANK([REF Top Track]),          "—", [REF Top Track])
			VAR _Album   = IF(ISBLANK([REF Top Album]),          "—", [REF Top Album])
			VAR _Plat    = IF(ISBLANK([REF Top Platform Group]), "—", [REF Top Platform Group])
			RETURN
			"<style>
			.hi{display:flex;gap:8px;width:100%;height:100%;font-family:'Segoe UI',sans-serif;padding:6px;box-sizing:border-box;}
			.c{flex:1;background:#121212;border-radius:8px;padding:14px 12px;border-left:3px solid #22cc66;display:flex;flex-direction:column;justify-content:center;overflow:hidden;min-width:0;}
			.l{color:#6c7e93;font-size:9px;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:6px;white-space:nowrap;}
			.v{color:#fff;font-size:13px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
			.g{color:#22cc66;}
			</style>
			<div class=""hi"">
			<div class=""c""><div class=""l"">🎤 Top Artist</div><div class=""v"">" & _Artist & "</div></div>
			<div class=""c""><div class=""l"">🎵 Top Track</div><div class=""v g"">" & _Track & "</div></div>
			<div class=""c""><div class=""l"">💿 Top Album</div><div class=""v"">" & _Album & "</div></div>
			<div class=""c""><div class=""l"">📱 Top Platform</div><div class=""v"">" & _Plat & "</div></div>
			</div>"
		displayFolder: 7_Custom_Visuals
		lineageTag: bbee53b2-cce8-4a2c-a9f6-0bd6e88b30f8

