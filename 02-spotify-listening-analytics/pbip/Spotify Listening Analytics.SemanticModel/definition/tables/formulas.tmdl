	measure 'VIS _HTML Card Total Hours' =
			
			VAR _Total     = [# Total Hours Played]
			VAR _PY        = [# Hours Previous Year]
			VAR _Growth    = [% Hours YoY Growth]
			-- colores y flecha según signo
			VAR _IsPos     = _Growth >= 0
			VAR _Color     = IF(_IsPos, "#4ade80", "#f87171")
			VAR _BgColor   = IF(_IsPos, "#052e16", "#450a0a")
			VAR _Border    = IF(_IsPos, "#166534", "#991b1b")
			VAR _Arrow     = IF(_IsPos, "↑", "↓")
			-- formateo de valores
			VAR _TotalFmt  = FORMAT(_Total,  "#,##0.0") & " h"
			VAR _PYFmt     = FORMAT(_PY,     "#,##0.0") & " h"
			VAR _GrowthFmt = FORMAT(ABS(_Growth), "0.0%")
			RETURN
			    "<div style='font-family:Segoe UI,sans-serif;padding:12px 18px;"
			        & "border-radius:10px;border:1.5px solid #2a2a2a;background:#121212;"
			        & "width:100%;height:100%;box-sizing:border-box;"
			        & "display:flex;flex-direction:column;justify-content:space-between;'>"
			    & "<div style='font-size:10px;font-weight:600;color:#5c6370;"
			        & "letter-spacing:.04em;'>"
			        & "Total Hours Played</div>"
			    & "<div style='font-size:25px;font-weight:600;color:#f1f1f1;"
			        & "line-height:1.1;'>" & _TotalFmt & "</div>"
			    & "<div style='display:flex;align-items:center;gap:8px;justify-content:flex-end;'>"
			        & "<span style='background:"   & _BgColor
			            & ";border:1px solid "     & _Border
			            & ";color:"                & _Color
			            & ";font-size:11px;font-weight:600;white-space:nowrap;"
			            & "padding:2px 8px;border-radius:99px;'>"
			            & _Arrow & " " & _GrowthFmt
			        & "</span>"
			        & "<span style='font-size:11px;color:#5c6370;'>"
			            & "vs PY: " & _PYFmt
			        & "</span>"
			    & "</div>"
			& "</div>"
		displayFolder: 7_Custom_Visuals
		lineageTag: 447568b1-051b-413d-abed-8b1853aa2cb9

	measure 'VIS _HTML Card Unique Artists' =
			
			VAR _Total  = [# Unique Artists]
			VAR _PY     = CALCULATE([# Unique Artists], SAMEPERIODLASTYEAR('dim_calendar'[Date]))
			VAR _Growth = DIVIDE(_Total - _PY, _PY)
			-- colores y flecha según signo
			VAR _IsPos     = _Growth >= 0
			VAR _Color     = IF(_IsPos, "#4ade80", "#f87171")
			VAR _BgColor   = IF(_IsPos, "#052e16", "#450a0a")
			VAR _Border    = IF(_IsPos, "#166534", "#991b1b")
			VAR _Arrow     = IF(_IsPos, "↑", "↓")
			-- formateo de valores
			VAR _TotalFmt  = FORMAT(_Total, "#,##0")
			VAR _PYFmt     = FORMAT(_PY,    "#,##0")
			VAR _GrowthFmt = FORMAT(ABS(_Growth), "0.0%")
			RETURN
			    "<div style='font-family:Segoe UI,sans-serif;padding:12px 18px;"
			        & "border-radius:10px;border:1.5px solid #2a2a2a;background:#141414;"
			        & "width:100%;height:100%;box-sizing:border-box;"
			        & "display:flex;flex-direction:column;justify-content:space-between;'>"
			    & "<div style='font-size:10px;font-weight:600;color:#5c6370;"
			        & "letter-spacing:.04em;'>"
			        & "Unique Artists</div>"
			    & "<div style='font-size:25px;font-weight:600;color:#f1f1f1;"
			        & "line-height:1.1;'>" & _TotalFmt & "</div>"
			    & "<div style='display:flex;align-items:center;gap:8px;justify-content:flex-end;'>"
			        & "<span style='background:"   & _BgColor
			            & ";border:1px solid "     & _Border
			            & ";color:"                & _Color
			            & ";font-size:11px;font-weight:600;white-space:nowrap;"
			            & "padding:2px 8px;border-radius:99px;'>"
			            & _Arrow & " " & _GrowthFmt
			        & "</span>"
			        & "<span style='font-size:11px;color:#5c6370;'>"
			            & "vs PY: " & _PYFmt
			        & "</span>"
			    & "</div>"
			& "</div>"
		displayFolder: 7_Custom_Visuals
		lineageTag: 1df433cc-bc2c-45ca-8e71-faa21e0eb3d8

