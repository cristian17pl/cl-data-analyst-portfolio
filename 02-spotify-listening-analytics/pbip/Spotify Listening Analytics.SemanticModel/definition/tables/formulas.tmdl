	measure 'REF Selected Date Range' =
			
			VAR MinSelectedDate = MIN(dim_calendar[Date])
			VAR MaxSelectedDate = MAX(dim_calendar[Date])
			RETURN
			    FORMAT(MinSelectedDate, "MMM d, yyyy") & " - " & FORMAT(MaxSelectedDate, "MMM d, yyyy")
		displayFolder: 6_Text Cards
