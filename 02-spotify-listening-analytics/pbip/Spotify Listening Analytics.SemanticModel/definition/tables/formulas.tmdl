	measure 'REF Top Track' =
			
			VAR TopTrack =
			    TOPN(
			        1,
			        ADDCOLUMNS(
			            VALUES(dim_song_artist[track_key]),
			            "@Track", CALCULATE(SELECTEDVALUE(dim_song_artist[master_metadata_track_name])),
			            "@Artist", CALCULATE(SELECTEDVALUE(dim_song_artist[master_metadata_album_artist_name])),
			            "@Streams", [# Streams],
			            "@Hours", [# Total Hours Played]
			        ),
			        [@Streams], DESC,
			        [@Hours], DESC,
			        [@Track], ASC
			    )
			RETURN
			    CONCATENATEX(TopTrack, [@Track] & " - " & [@Artist], ", ")
		displayFolder: 6_Text Cards
		lineageTag: 9648bd4d-9648-4e8e-8f78-f80e6e51e50e

	measure 'REF Top Artist' =
			
			VAR TopArtist =
			    TOPN(
			        1,
			        ADDCOLUMNS(
			            VALUES(dim_song_artist[master_metadata_album_artist_name]),
			            "@Artist", dim_song_artist[master_metadata_album_artist_name],
			            "@Hours", [# Total Hours Played],
			            "@Streams", [# Streams]
			        ),
			        [@Hours], DESC,
			        [@Streams], DESC,
			        [@Artist], ASC
			    )
			RETURN
			    CONCATENATEX(TopArtist, [@Artist], ", ")
		displayFolder: 6_Text Cards
		lineageTag: b6007f66-6816-4245-9a01-a6696d3568ad

	measure 'REF Top Platform Group' =
			
