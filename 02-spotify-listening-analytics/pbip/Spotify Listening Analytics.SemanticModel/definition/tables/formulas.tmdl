	measure 'VIS _HTML Card Unique Tracks' = ```
			
			VAR _Total  = [# Unique Tracks]
			VAR _PY     = CALCULATE([# Unique Tracks], SAMEPERIODLASTYEAR('dim_calendar'[Date])) 
			VAR _Growth = DIVIDE(_Total - _PY, _PY)
