	partition dim_calendar = calculated
		mode: import
		source =
				
				VAR MinDate =
				    DATEVALUE ( MIN ( fact_streaming_history[ts] ) )
				VAR MaxDate =
				    DATEVALUE ( MAX ( fact_streaming_history[ts] ) )
				RETURN
				ADDCOLUMNS (
				    CALENDAR ( MinDate, MaxDate ),
				
				    "date_key", FORMAT ( [Date], "YYYYMMDD" ),
				    "year", YEAR ( [Date] ),
				    "quarter_number", QUARTER ( [Date] ),
				    "quarter", "Q" & QUARTER ( [Date] ),
				    "year_quarter", YEAR ( [Date] ) & " Q" & QUARTER ( [Date] ),
				
				    "month_number", MONTH ( [Date] ),
				    "month_name", SWITCH ( MONTH ( [Date] ), 1, "January", 2, "February", 3, "March", 4, "April", 5, "May", 6, "June", 7, "July", 8, "August", 9, "September", 10, "October", 11, "November", 12, "December" ),
				    "month_short", SWITCH ( MONTH ( [Date] ), 1, "Jan", 2, "Feb", 3, "Mar", 4, "Apr", 5, "May", 6, "Jun", 7, "Jul", 8, "Aug", 9, "Sep", 10, "Oct", 11, "Nov", 12, "Dec" ),
				    "year_month", FORMAT ( [Date], "YYYY-MM" ),
				    "year_month_name", YEAR ( [Date] ) & " " & SWITCH ( MONTH ( [Date] ), 1, "Jan", 2, "Feb", 3, "Mar", 4, "Apr", 5, "May", 6, "Jun", 7, "Jul", 8, "Aug", 9, "Sep", 10, "Oct", 11, "Nov", 12, "Dec" ),
				
				    "week_number", WEEKNUM ( [Date], 2 ),
				    "year_week", YEAR ( [Date] ) & "-W" & FORMAT ( WEEKNUM ( [Date], 2 ), "00" ),
				
				    "day", DAY ( [Date] ),
				    "day_name", SWITCH ( WEEKDAY ( [Date], 2 ), 1, "Monday", 2, "Tuesday", 3, "Wednesday", 4, "Thursday", 5, "Friday", 6, "Saturday", 7, "Sunday" ),
				    "day_short", SWITCH ( WEEKDAY ( [Date], 2 ), 1, "Mon", 2, "Tue", 3, "Wed", 4, "Thu", 5, "Fri", 6, "Sat", 7, "Sun" ),
				    "day_of_week_number", WEEKDAY ( [Date], 2 ),
				
				    "is_weekend", IF ( WEEKDAY ( [Date], 2 ) >= 6, TRUE (), FALSE () ),
				    "week_type", IF ( WEEKDAY ( [Date], 2 ) >= 6, "Weekend", "Weekday" )
				)

	annotation PBI_Id = a45078982e5b40859ae6c8ad4ab5ec57

