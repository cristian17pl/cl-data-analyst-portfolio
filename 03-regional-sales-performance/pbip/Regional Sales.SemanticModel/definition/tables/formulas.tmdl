	measure '$ Revenue in Target Period' =
			
			VAR _TargetMonths =
			    VALUES(fact_targets[YearMonth])
			RETURN
			    CALCULATE(
			        [$ Total Revenue],
			        KEEPFILTERS(
			            TREATAS(
			                _TargetMonths,
			                dim_date[YearMonth]
			            )
			        )
			    )
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: 3_Targets\$
		lineageTag: 953e280a-4684-4f7b-b9ad-898de8441da1

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'VIS HTML Executive KPI Cards' =
			
			VAR _Revenue = [$ Total Revenue]
			VAR _RevenuePY = [$ Revenue PY]
			VAR _RevenueYoY = [% Revenue YoY]
			
			VAR _RevenueGood =
			    COALESCE(_RevenueYoY, 0) >= 0
			
			VAR _RevenueColor =
			    IF(_RevenueGood, "#3DBA7E", "#F87171")
			
			VAR _RevenuePill =
			    IF(_RevenueGood, "#123F35", "#4A202A")
			
			VAR _RevenueArrow =
			    IF(
			        ISBLANK(_RevenueYoY),
			        "•",
			        IF(_RevenueGood, "↑", "↓")
			    )
			
			VAR _RevenueFmt =
			    SWITCH(
			        TRUE(),
			        ABS(_Revenue) >= 1000000000,
			            FORMAT(_Revenue / 1000000000, "$0.0B"),
			        ABS(_Revenue) >= 1000000,
			            FORMAT(_Revenue / 1000000, "$0.0M"),
			        ABS(_Revenue) >= 1000,
			            FORMAT(_Revenue / 1000, "$0.0K"),
			        FORMAT(_Revenue, "$#,0")
			    )
			
			VAR _RevenuePYFmt =
			    SWITCH(
			        TRUE(),
			        ISBLANK(_RevenuePY), "—",
			        ABS(_RevenuePY) >= 1000000000,
			            FORMAT(_RevenuePY / 1000000000, "$0.0B"),
			        ABS(_RevenuePY) >= 1000000,
			            FORMAT(_RevenuePY / 1000000, "$0.0M"),
			        ABS(_RevenuePY) >= 1000,
			            FORMAT(_RevenuePY / 1000, "$0.0K"),
			        FORMAT(_RevenuePY, "$#,0")
			    )
			
			VAR _RevenueYoYFmt =
			    IF(
			        ISBLANK(_RevenueYoY),
			        "—",
			        FORMAT(ABS(_RevenueYoY), "0.0%")
			    )
			
			VAR _Margin = [% Margin Rate]
			VAR _GrossMargin = [$ Gross Margin]
			
			VAR _MarginPY =
			    CALCULATE(
			        [% Margin Rate],
			        SAMEPERIODLASTYEAR(dim_date[Date])
			    )
			
			VAR _MarginDelta =
			    _Margin - _MarginPY
			
			VAR _MarginGood =
			    COALESCE(_MarginDelta, 0) >= 0
			
			VAR _MarginColor =
			    IF(_MarginGood, "#3DBA7E", "#F87171")
			
			VAR _MarginPill =
			    IF(_MarginGood, "#123F35", "#4A202A")
			
			VAR _MarginArrow =
			    IF(
			        ISBLANK(_MarginDelta),
			        "•",
			        IF(_MarginGood, "↑", "↓")
			    )
			
			VAR _MarginFmt =
			    FORMAT(_Margin, "0.0%")
			
			VAR _GrossMarginFmt =
			    SWITCH(
			        TRUE(),
			        ABS(_GrossMargin) >= 1000000000,
			            FORMAT(_GrossMargin / 1000000000, "$0.0B"),
			        ABS(_GrossMargin) >= 1000000,
			            FORMAT(_GrossMargin / 1000000, "$0.0M"),
			        ABS(_GrossMargin) >= 1000,
			            FORMAT(_GrossMargin / 1000, "$0.0K"),
			        FORMAT(_GrossMargin, "$#,0")
			    )
			
			VAR _MarginDeltaFmt =
			    IF(
			        ISBLANK(_MarginDelta),
			        "—",
			        FORMAT(ABS(_MarginDelta) * 100, "0.0") & " pp"
			    )
			
			VAR _Attainment = [% Target Attainment]
			VAR _Target = [$ Target Revenue]
			VAR _Variance = [$ Variance to Target]
			
			VAR _AttainmentGood =
			    COALESCE(_Attainment, 0) >= 1
			
			VAR _AttainmentColor =
			    IF(_AttainmentGood, "#3DBA7E", "#F87171")
			
			VAR _AttainmentPill =
			    IF(_AttainmentGood, "#123F35", "#4A202A")
			
			VAR _AttainmentLabel =
			    IF(_AttainmentGood, "Above plan", "Below plan")
			
			VAR _AttainmentFmt =
			    IF(
			        ISBLANK(_Attainment),
			        "—",
			        FORMAT(_Attainment, "0.0%")
			    )
			
			VAR _TargetFmt =
			    SWITCH(
			        TRUE(),
			        ISBLANK(_Target), "—",
			        ABS(_Target) >= 1000000000,
			            FORMAT(_Target / 1000000000, "$0.0B"),
			        ABS(_Target) >= 1000000,
			            FORMAT(_Target / 1000000, "$0.0M"),
			        ABS(_Target) >= 1000,
			            FORMAT(_Target / 1000, "$0.0K"),
			        FORMAT(_Target, "$#,0")
			    )
			
			VAR _VarianceFmt =
			    SWITCH(
			        TRUE(),
			        ISBLANK(_Variance), "—",
			        ABS(_Variance) >= 1000000000,
			            FORMAT(ABS(_Variance) / 1000000000, "$0.0B"),
			        ABS(_Variance) >= 1000000,
			            FORMAT(ABS(_Variance) / 1000000, "$0.0M"),
			        ABS(_Variance) >= 1000,
			            FORMAT(ABS(_Variance) / 1000, "$0.0K"),
			        FORMAT(ABS(_Variance), "$#,0")
			    )
			
			VAR _ProgressWidth =
			    FORMAT(
			        MIN(
			            1,
			            MAX(
			                0,
			                COALESCE(_Attainment, 0)
			            )
			        ),
			        "0%"
			    )
			
			RETURN
			    "<style>
			    .kpi-wrap{
			        display:grid;
			        grid-template-columns:repeat(3,minmax(0,1fr));
			        gap:12px;
			        width:100%;
			        height:100%;
			        padding:3px;
			        box-sizing:border-box;
			        font-family:'Segoe UI',sans-serif;
			    }
			
			    .kpi{
			        background:#0E2841;
			        border:1px solid #29445F;
			        border-left:5px solid #C8A84B;
			        border-radius:8px;
			        padding:9px 13px;
			        display:flex;
			        flex-direction:column;
			        justify-content:space-between;
			        min-width:0;
			        overflow:hidden;
			        box-sizing:border-box;
			    }
			
			    .label{
			        color:#B3C7D9;
			        font-size:9px;
			        font-weight:700;
			        letter-spacing:1.1px;
			        line-height:1;
			        text-transform:uppercase;
			        white-space:nowrap;
			    }
			
			    .value{
			        color:#FFFFFF;
			        font-size:25px;
			        font-weight:700;
			        line-height:1;
			        margin:4px 0;
			        white-space:nowrap;
			    }
			
			    .footer{
			        display:flex;
			        align-items:center;
			        justify-content:space-between;
			        gap:7px;
			        min-width:0;
			    }
			
			    .context{
			        color:#7F96AA;
			        font-size:9px;
			        line-height:1;
			        white-space:nowrap;
			        overflow:hidden;
			        text-overflow:ellipsis;
			    }
			
			    .pill{
			        font-size:9px;
			        font-weight:700;
			        line-height:1;
			        padding:3px 7px;
			        border-radius:99px;
			        white-space:nowrap;
			    }
			
			    .track{
			        height:4px;
			        background:#183A57;
			        border-radius:99px;
			        overflow:hidden;
			        margin:0 0 5px;
			    }
			
			    .fill{
			        height:100%;
			        border-radius:99px;
			    }
			    </style>
			
			    <div class='kpi-wrap'>
			
			        <div class='kpi'>
			            <div class='label'>
			                Revenue
			            </div>
			
			            <div class='value'>" &
			                _RevenueFmt &
			            "</div>
			
			            <div class='footer'>
			                <span class='context'>
			                    vs PY: " & _RevenuePYFmt &
			                "</span>
			
			                <span
			                    class='pill'
			                    style='color:" & _RevenueColor &
			                    ";background:" & _RevenuePill & ";'
			                >" &
			                    _RevenueArrow & " " &
			                    _RevenueYoYFmt & " YoY
			                </span>
			            </div>
			        </div>
			
			        <div class='kpi'>
			            <div class='label'>
			                Profitability
			            </div>
			
			            <div class='value'>" &
			                _MarginFmt &
			            "</div>
			
			            <div class='footer'>
			                <span class='context'>" &
			                    _GrossMarginFmt &
			                    " gross margin
			                </span>
			
			                <span
			                    class='pill'
			                    style='color:" & _MarginColor &
			                    ";background:" & _MarginPill & ";'
			                >" &
			                    _MarginArrow & " " &
			                    _MarginDeltaFmt & " YoY
			                </span>
			            </div>
			        </div>
			
			        <div class='kpi'>
			            <div class='label'>
			                Target Performance
			            </div>
			
			            <div class='value'>" &
			                _AttainmentFmt &
			            "</div>
			
			            <div class='track'>
			                <div
			                    class='fill'
			                    style='width:" & _ProgressWidth &
			                    ";background:" & _AttainmentColor & ";'
			                ></div>
			            </div>
			
			            <div class='footer'>
			                <span class='context'>
			                    Target " & _TargetFmt &
			                "</span>
			
			                <span
			                    class='pill'
			                    style='color:" & _AttainmentColor &
			                    ";background:" & _AttainmentPill & ";'
			                >" &
			                    _VarianceFmt & " " &
			                    _AttainmentLabel &
			                "</span>
			            </div>
			        </div>
			
			    </div>"
		displayFolder: 0_Custom_Visuals
		lineageTag: 6edcfeae-efb9-4e87-a6bb-dd05bae05a11

	measure '$ Revenue Change vs Comparable PY' =
			VAR _LastVisibleDate = MAX(dim_date[Date])
			VAR _CurrentYear = YEAR(_LastVisibleDate)
			VAR _ComparisonEndDate =
				DATE(
					_CurrentYear - 1,
					MONTH(_LastVisibleDate),
					DAY(_LastVisibleDate)
				)
			VAR _CurrentPeriodRevenue =
				CALCULATE(
					[$ Total Revenue],
					REMOVEFILTERS(dim_date),
					dim_date[Date] >= DATE(_CurrentYear, 1, 1),
					dim_date[Date] <= _LastVisibleDate
				)
			VAR _PreviousPeriodRevenue =
				CALCULATE(
					[$ Total Revenue],
					REMOVEFILTERS(dim_date),
					dim_date[Date] >= DATE(_CurrentYear - 1, 1, 1),
					dim_date[Date] <= _ComparisonEndDate
				)
			RETURN
				IF(
					ISBLANK(_LastVisibleDate),
					BLANK(),
					_CurrentPeriodRevenue - _PreviousPeriodRevenue
				)
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: 4_Time Intelligence\$
		lineageTag: b2b0a74b-e02c-4992-9c89-4eda48e3b0ee

	measure '% Revenue Mix' =
			DIVIDE(
				[$ Total Revenue],
				CALCULATE(
					[$ Total Revenue],
					REMOVEFILTERS(dim_product[Category])
				)
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 1_Sales\%
		lineageTag: 5011b295-2486-4872-9104-4d73e48945b6

	measure 'REF Category Revenue Bar Color' =
			
			VAR _CurrentRevenue =
			    [$ Total Revenue]
			
			VAR _VisibleCategories =
			    ALLSELECTED(dim_product[Category])
			
			VAR _HighestRevenue =
			    MAXX(
			        _VisibleCategories,
			        CALCULATE([$ Total Revenue])
			    )
			
			VAR _LowestRevenue =
			    MINX(
			        FILTER(
			            _VisibleCategories,
			            NOT ISBLANK(
			                CALCULATE([$ Total Revenue])
			            )
			        ),
			        CALCULATE([$ Total Revenue])
			    )
			
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(_CurrentRevenue), BLANK(),
			        _CurrentRevenue = _HighestRevenue, "#C8A84B",
			        _CurrentRevenue = _LowestRevenue, "#F04444",
			        "#1E6FBF"
			    )
		displayFolder: 7_Text Cards
		lineageTag: 35f4fd88-64ab-4eb8-9d84-578ea9a24870

	measure 'VIS HTML Current Leaders' =
			
			VAR _TotalRevenue =
			    [$ Total Revenue]
			
			VAR _RegionTable =
			    TOPN(
			        1,
			        VALUES(dim_territory[Region]),
			        [$ Total Revenue], DESC,
			        dim_territory[Region], ASC
			    )
			
			VAR _CategoryTable =
			    TOPN(
			        1,
			        VALUES(dim_product[Category]),
			        [$ Total Revenue], DESC,
			        dim_product[Category], ASC
			    )
			
			VAR _ProductTable =
			    TOPN(
			        1,
			        VALUES(dim_product[ProductName]),
			        [$ Total Revenue], DESC,
			        dim_product[ProductName], ASC
			    )
			
			VAR _TopRegion =
			    MAXX(
			        _RegionTable,
			        dim_territory[Region]
			    )
			
			VAR _TopCategory =
			    MAXX(
			        _CategoryTable,
			        dim_product[Category]
			    )
			
			VAR _TopProduct =
			    MAXX(
			        _ProductTable,
			        dim_product[ProductName]
			    )
			
			VAR _TopRegionRevenue =
			    MAXX(
			        _RegionTable,
			        [$ Total Revenue]
			    )
			
			VAR _TopCategoryRevenue =
			    MAXX(
			        _CategoryTable,
			        [$ Total Revenue]
			    )
			
			VAR _TopProductRevenue =
			    MAXX(
			        _ProductTable,
			        [$ Total Revenue]
			    )
			
			VAR _RegionShare =
			    DIVIDE(
			        _TopRegionRevenue,
			        _TotalRevenue
			    )
			
			VAR _CategoryShare =
			    DIVIDE(
			        _TopCategoryRevenue,
			        _TotalRevenue
			    )
			
			VAR _ProductShare =
			    DIVIDE(
			        _TopProductRevenue,
			        _TotalRevenue
			    )
			
			VAR _RegionDisplay =
			    COALESCE(
			        _TopRegion,
			        "No region"
			    )
			
			VAR _CategoryDisplay =
			    COALESCE(
			        _TopCategory,
			        "No category"
			    )
			
			VAR _ProductDisplay =
			    COALESCE(
			        _TopProduct,
			        "No product"
			    )
			
			VAR _RegionRevenueFmt =
			    SWITCH(
			        TRUE(),
			        ISBLANK(_TopRegionRevenue), "—",
			        ABS(_TopRegionRevenue) >= 1000000000,
			            FORMAT(_TopRegionRevenue / 1000000000, "$0.0B"),
			        ABS(_TopRegionRevenue) >= 1000000,
			            FORMAT(_TopRegionRevenue / 1000000, "$0.0M"),
			        ABS(_TopRegionRevenue) >= 1000,
			            FORMAT(_TopRegionRevenue / 1000, "$0.0K"),
			        FORMAT(_TopRegionRevenue, "$#,0")
			    )
			
			VAR _CategoryRevenueFmt =
			    SWITCH(
			        TRUE(),
			        ISBLANK(_TopCategoryRevenue), "—",
			        ABS(_TopCategoryRevenue) >= 1000000000,
			            FORMAT(_TopCategoryRevenue / 1000000000, "$0.0B"),
			        ABS(_TopCategoryRevenue) >= 1000000,
			            FORMAT(_TopCategoryRevenue / 1000000, "$0.0M"),
			        ABS(_TopCategoryRevenue) >= 1000,
			            FORMAT(_TopCategoryRevenue / 1000, "$0.0K"),
			        FORMAT(_TopCategoryRevenue, "$#,0")
			    )
			
			VAR _ProductRevenueFmt =
			    SWITCH(
			        TRUE(),
			        ISBLANK(_TopProductRevenue), "—",
			        ABS(_TopProductRevenue) >= 1000000000,
			            FORMAT(_TopProductRevenue / 1000000000, "$0.0B"),
			        ABS(_TopProductRevenue) >= 1000000,
			            FORMAT(_TopProductRevenue / 1000000, "$0.0M"),
			        ABS(_TopProductRevenue) >= 1000,
			            FORMAT(_TopProductRevenue / 1000, "$0.0K"),
			        FORMAT(_TopProductRevenue, "$#,0")
			    )
			
			VAR _RegionShareFmt =
			    IF(
			        ISBLANK(_RegionShare),
			        "—",
			        FORMAT(_RegionShare, "0.0%")
			    )
			
			VAR _CategoryShareFmt =
			    IF(
			        ISBLANK(_CategoryShare),
			        "—",
			        FORMAT(_CategoryShare, "0.0%")
			    )
			
			VAR _ProductShareFmt =
			    IF(
			        ISBLANK(_ProductShare),
			        "—",
			        FORMAT(_ProductShare, "0.0%")
			    )
			
			RETURN
			    "<style>
			    html,
			    body{
			        width:100%;
			        height:100%;
			        margin:0;
			        padding:0;
			        overflow:hidden;
			        background:transparent;
			    }
			
			    *{
			        box-sizing:border-box;
			    }
			
			    .leaders{
			        width:100vw;
			        height:100vh;
			        min-height:100%;
			        overflow:hidden;
			        display:grid;
			        grid-template-rows:auto 1fr;
			        background:#0E2841;
			        border:1px solid #29445F;
			        border-radius:8px;
			        padding:17px 18px 16px;
			        font-family:'Segoe UI',sans-serif;
			    }
			
			    .leaders-header{
			        display:flex;
			        align-items:flex-start;
			        justify-content:space-between;
			        gap:12px;
			        padding-bottom:14px;
			        border-bottom:1px solid #29445F;
			    }
			
			    .leaders-title-group{
			        min-width:0;
			    }
			
			    .leaders-title{
			        color:#FFFFFF;
			        font-size:17px;
			        font-weight:700;
			        line-height:1;
			    }
			
			    .leaders-subtitle{
			        color:#7F96AA;
			        font-size:10px;
			        line-height:1;
			        margin-top:7px;
			    }
			
			    .leaders-context{
			        color:#7F96AA;
			        font-size:9px;
			        font-weight:700;
			        letter-spacing:1.1px;
			        line-height:1;
			        text-transform:uppercase;
			        white-space:nowrap;
			        padding-top:2px;
			    }
			
			    .leaders-grid{
			        display:grid;
			        grid-template-columns:1fr 1fr 1.45fr;
			        min-height:0;
			        height:100%;
			    }
			
			    .leader{
			        position:relative;
			        min-width:0;
			        display:flex;
			        flex-direction:column;
			        justify-content:center;
			        padding:12px 17px 2px;
			        overflow:hidden;
			    }
			
			    .leader:first-child{
			        padding-left:0;
			    }
			
			    .leader:last-child{
			        padding-right:0;
			    }
			
			    .leader:not(:last-child){
			        border-right:1px solid #29445F;
			    }
			
			    .leader-number{
			        position:absolute;
			        top:12px;
			        right:14px;
			        color:#29445F;
			        font-size:30px;
			        font-weight:800;
			        line-height:1;
			    }
			
			    .leader-label{
			        color:#C8A84B;
			        font-size:9px;
			        font-weight:700;
			        letter-spacing:1.1px;
			        line-height:1;
			        text-transform:uppercase;
			        white-space:nowrap;
			        margin-bottom:9px;
			    }
			
			    .leader-value{
			        position:relative;
			        z-index:1;
			        color:#FFFFFF;
			        font-size:21px;
			        font-weight:650;
			        line-height:1.1;
			        white-space:nowrap;
			        overflow:hidden;
			        text-overflow:ellipsis;
			        padding-right:5px;
			    }
			
			    .leader-product{
			        font-size:18px;
			        white-space:normal;
			        display:-webkit-box;
			        -webkit-box-orient:vertical;
			        -webkit-line-clamp:2;
			        max-height:42px;
			    }
			
			    .leader-metrics{
			        display:flex;
			        align-items:center;
			        gap:7px;
			        margin-top:11px;
			        min-width:0;
			    }
			
			    .revenue-pill{
			        color:#FFFFFF;
			        background:#173A57;
			        border:1px solid #294F6B;
			        border-radius:99px;
			        padding:4px 9px;
			        font-size:10px;
			        font-weight:700;
			        line-height:1;
			        white-space:nowrap;
			    }
			
			    .share{
			        color:#7F96AA;
			        font-size:9px;
			        line-height:1;
			        white-space:nowrap;
			    }
			    </style>
			
			    <div class='leaders'>
			
			        <div class='leaders-header'>
			
			            <div class='leaders-title-group'>
			                <div class='leaders-title'>
			                    Current leaders
			                </div>
			
			                <div class='leaders-subtitle'>
			                    Highest-revenue contributors in the selected context
			                </div>
			            </div>
			
			            <div class='leaders-context'>
			                Region · Category · Product
			            </div>
			
			        </div>
			
			        <div class='leaders-grid'>
			
			            <div class='leader'>
			
			                <div class='leader-number'>
			                    01
			                </div>
			
			                <div class='leader-label'>
			                    Top region
			                </div>
			
			                <div class='leader-value'>" &
			                    _RegionDisplay &
			                "</div>
			
			                <div class='leader-metrics'>
			                    <span class='revenue-pill'>" &
			                        _RegionRevenueFmt &
			                    "</span>
			
			                    <span class='share'>" &
			                        _RegionShareFmt &
			                        " of revenue
			                    </span>
			                </div>
			
			            </div>
			
			            <div class='leader'>
			
			                <div class='leader-number'>
			                    02
			                </div>
			
			                <div class='leader-label'>
			                    Top category
			                </div>
			
			                <div class='leader-value'>" &
			                    _CategoryDisplay &
			                "</div>
			
			                <div class='leader-metrics'>
			                    <span class='revenue-pill'>" &
			                        _CategoryRevenueFmt &
			                    "</span>
			
			                    <span class='share'>" &
			                        _CategoryShareFmt &
			                        " of revenue
			                    </span>
			                </div>
			
			            </div>
			
			            <div class='leader'>
			
			                <div class='leader-number'>
			                    03
			                </div>
			
			                <div class='leader-label'>
			                    Top product
			                </div>
			
			                <div
			                    class='leader-value leader-product'
			                    title='" & _ProductDisplay & "'
			                >" &
			                    _ProductDisplay &
			                "</div>
			
			                <div class='leader-metrics'>
			                    <span class='revenue-pill'>" &
			                        _ProductRevenueFmt &
			                    "</span>
			
			                    <span class='share'>" &
			                        _ProductShareFmt &
			                        " of revenue
			                    </span>
			                </div>
			
			            </div>
			
			        </div>
			
			    </div>"
		displayFolder: 0_Custom_Visuals
		lineageTag: 96e25f47-1913-4453-ab8a-95b74f410b63

	measure '% Country Revenue Share' =
			DIVIDE(
				[$ Total Revenue],
				CALCULATE(
					[$ Total Revenue],
					REMOVEFILTERS(dim_territory[CountryCode])
				)
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 1_Sales\%
		lineageTag: e6d2abcb-9999-4568-b0b0-95ac1dd95140

	measure 'REF Region Attainment Bar Color' =
			VAR _CurrentValue = [% Target Attainment]
			VAR _VisibleRegions = ALLSELECTED(dim_territory[Region])
			VAR _HighestValue = MAXX(_VisibleRegions, CALCULATE([% Target Attainment]))
			VAR _LowestValue =
				MINX(
					FILTER(_VisibleRegions, NOT ISBLANK(CALCULATE([% Target Attainment]))),
					CALCULATE([% Target Attainment])
				)
			RETURN
				SWITCH(
					TRUE(),
					ISBLANK(_CurrentValue), BLANK(),
					_CurrentValue = _HighestValue, "#C8A84B",
					_CurrentValue = _LowestValue, "#F04444",
					"#1E6FBF"
				)
		displayFolder: 7_Text Cards
		lineageTag: 7d199b31-a692-421c-b16d-c59929513be0

	measure '$ Revenue Top 10 Subcategory' =
			VAR _CurrentSubcategory = SELECTEDVALUE(dim_product[Subcategory])
			VAR _TopSubcategories =
				TOPN(
					10,
					ALLSELECTED(dim_product[Subcategory]),
					[$ Total Revenue], DESC,
					dim_product[Subcategory], ASC
				)
			RETURN
				IF(
					CONTAINS(
						_TopSubcategories,
						dim_product[Subcategory],
						_CurrentSubcategory
					),
					[$ Total Revenue]
				)
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: 6_Rankings\$
		lineageTag: a51f2f0f-91bf-407e-ae47-b5a8b8171dd9

	measure 'REF Subcategory Revenue Bar Color' =
			VAR _CurrentRevenue = [$ Total Revenue]
			VAR _TopSubcategories =
				TOPN(
					10,
					ALLSELECTED(dim_product[Subcategory]),
					[$ Total Revenue], DESC,
					dim_product[Subcategory], ASC
				)
			VAR _HighestRevenue = MAXX(_TopSubcategories, CALCULATE([$ Total Revenue]))
			VAR _LowestRevenue = MINX(_TopSubcategories, CALCULATE([$ Total Revenue]))
			VAR _IsTopTen = CONTAINS(_TopSubcategories, dim_product[Subcategory], SELECTEDVALUE(dim_product[Subcategory]))
			RETURN
				SWITCH(
					TRUE(),
					NOT _IsTopTen || ISBLANK(_CurrentRevenue), BLANK(),
					_CurrentRevenue = _HighestRevenue, "#C8A84B",
					_CurrentRevenue = _LowestRevenue, "#F04444",
					"#1E6FBF"
				)
		displayFolder: 7_Text Cards
		lineageTag: 7c08f456-82ae-429c-916a-d96ca84412d1

	measure '$ Revenue Top 20 Product' = IF([# Product Rank by Revenue] <= 20, [$ Total Revenue])
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: 6_Rankings\$
		lineageTag: e02fd911-73dd-432a-b3b6-2a585a7f226c

	measure '% Margin Rate Top 20 Product' = IF([# Product Rank by Revenue] <= 20, [% Margin Rate])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 6_Rankings\%
		lineageTag: 7aeb0c46-2868-41c5-9eec-587aa478b934

	measure '# Units Top 20 Product' = IF([# Product Rank by Revenue] <= 20, [# Units Sold])
		formatString: #,0
		displayFolder: 6_Rankings\#
		lineageTag: 776b71df-d943-4baa-a925-190f066f376b

	measure 'REF Product Margin Font Color' =
			
			VAR _Margin =
			    [% Margin Rate]
			
			RETURN
			    IF(
			        ISBLANK(_Margin),
			        "#FFFFFF",
			        IF(
			            _Margin < 0,
			            "#FF3131"
			        )
			    )
		displayFolder: 7_Text Cards
		lineageTag: 029c7810-c136-420f-94d4-c762207c1cb2

	measure 'Selected Metric Value' =
			VAR _SelectedParameter =
				SELECTCOLUMNS(
					SUMMARIZE(
						'Metric selector',
						'Metric selector'[Metric selector],
						'Metric selector'[Metric selector Fields]
					),
					"MetricName", 'Metric selector'[Metric selector]
				)
			VAR _Metric =
				IF(
					COUNTROWS(_SelectedParameter) = 1,
					MAXX(_SelectedParameter, [MetricName]),
					"$ Total Revenue"
				)
			RETURN
				SWITCH(
					_Metric,
					"$ Total Revenue", [$ Total Revenue],
					"$ Gross Margin", [$ Gross Margin],
					"# Units Sold", [# Units Sold],
					"# Orders", [# Orders],
					[$ Total Revenue]
				)
		formatString: #,0
		displayFolder: 7_Selectors
		lineageTag: cde62d54-f297-43cf-ad27-cb0c41a850c8

	measure '$ Gross Margin YTD' = TOTALYTD([$ Gross Margin], dim_date[Date])
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: 4_Time Intelligence\$
		lineageTag: 6dd057dd-79cb-46ea-a4e0-e7b066d46658

	measure '$ Gross Margin PY YTD' = CALCULATE([$ Gross Margin YTD], SAMEPERIODLASTYEAR(dim_date[Date]))
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: 4_Time Intelligence\$
		lineageTag: 00609b27-cae2-42c4-b3db-d2a0aa5bf9de

	measure '% Margin Rate YTD' = DIVIDE([$ Gross Margin YTD], [$ Revenue YTD])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 4_Time Intelligence\%
		lineageTag: 388e3608-3de3-4b90-8716-6b406fc9286e

	measure '% Margin Rate PY YTD' = DIVIDE([$ Gross Margin PY YTD], [$ Revenue PY YTD])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 4_Time Intelligence\%
		lineageTag: a8d854d0-92c0-447d-9d12-850bb14b8a40

	measure 'pp Margin Rate vs PY YTD' = 100 * ([% Margin Rate YTD] - [% Margin Rate PY YTD])
		formatString: 0.0 "pp";-0.0 "pp";0.0 "pp"
		displayFolder: 4_Time Intelligence\%
		lineageTag: 98b15329-b402-49eb-995e-eef8724acd88

	measure '# Orders YTD' = TOTALYTD([# Orders], dim_date[Date])
		formatString: #,0
		displayFolder: 4_Time Intelligence\#
		lineageTag: 98c7bcd8-543f-41f6-abdc-3c9d451865a8

	measure '# Orders PY YTD' = CALCULATE([# Orders YTD], SAMEPERIODLASTYEAR(dim_date[Date]))
		formatString: #,0
		displayFolder: 4_Time Intelligence\#
		lineageTag: 825bcf0c-fddb-4cf7-b23c-a1b3e7aaeadc

	measure '% Orders YoY YTD' = DIVIDE([# Orders YTD] - [# Orders PY YTD], [# Orders PY YTD])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 4_Time Intelligence\%
		lineageTag: 1cc82c2c-0c77-42db-a8eb-b071fb01f96a

	measure '# Units YTD' = TOTALYTD([# Units Sold], dim_date[Date])
		formatString: #,0
		displayFolder: 4_Time Intelligence\#
		lineageTag: a9d08102-43d8-458a-acf8-7d4e6dd7f43d

	measure '$ Avg Order Value YTD' = DIVIDE([$ Revenue YTD], [# Orders YTD])
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: 4_Time Intelligence\$
		lineageTag: a5b4db02-6069-4028-a9e6-7063fe827c58

	measure 'VIS HTML Trend KPI Cards' =
			VAR _RevenueYTD = [$ Revenue YTD]
			VAR _RevenuePYYTD = [$ Revenue PY YTD]
			VAR _RevenueYoY = [% Revenue YoY YTD]
			VAR _RevenueGood = COALESCE(_RevenueYoY, 0) >= 0
			VAR _RevenueColor =
				SWITCH(
					TRUE(),
					ISBLANK(_RevenueYoY), "#B3C7D9",
					_RevenueGood, "#3DBA7E",
					"#F87171"
				)
			VAR _RevenuePill =
				SWITCH(
					TRUE(),
					ISBLANK(_RevenueYoY), "#183A57",
					_RevenueGood, "#123F35",
					"#4A202A"
				)
			VAR _RevenueArrow =
				IF(
					ISBLANK(_RevenueYoY),
					"&#8226;",
					IF(_RevenueGood, "&#8593;", "&#8595;")
				)
			VAR _RevenueYTDFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_RevenueYTD), "&mdash;",
					ABS(_RevenueYTD) >= 1000000000, FORMAT(_RevenueYTD / 1000000000, "$0.0B"),
					ABS(_RevenueYTD) >= 1000000, FORMAT(_RevenueYTD / 1000000, "$0.0M"),
					ABS(_RevenueYTD) >= 1000, FORMAT(_RevenueYTD / 1000, "$0.0K"),
					FORMAT(_RevenueYTD, "$#,0")
				)
			VAR _RevenuePYYTDFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_RevenuePYYTD), "&mdash;",
					ABS(_RevenuePYYTD) >= 1000000000, FORMAT(_RevenuePYYTD / 1000000000, "$0.0B"),
					ABS(_RevenuePYYTD) >= 1000000, FORMAT(_RevenuePYYTD / 1000000, "$0.0M"),
					ABS(_RevenuePYYTD) >= 1000, FORMAT(_RevenuePYYTD / 1000, "$0.0K"),
					FORMAT(_RevenuePYYTD, "$#,0")
				)
			VAR _RevenueYoYFmt =
				IF(
					ISBLANK(_RevenueYoY),
					"&mdash;",
					FORMAT(ABS(_RevenueYoY), "0.0%")
				)
			
			VAR _MarginRateYTD = [% Margin Rate YTD]
			VAR _GrossMarginYTD = [$ Gross Margin YTD]
			VAR _MarginDeltaPP = [pp Margin Rate vs PY YTD]
			VAR _MarginGood = COALESCE(_MarginDeltaPP, 0) >= 0
			VAR _MarginColor =
				SWITCH(
					TRUE(),
					ISBLANK(_MarginDeltaPP), "#B3C7D9",
					_MarginGood, "#3DBA7E",
					"#F87171"
				)
			VAR _MarginPill =
				SWITCH(
					TRUE(),
					ISBLANK(_MarginDeltaPP), "#183A57",
					_MarginGood, "#123F35",
					"#4A202A"
				)
			VAR _MarginArrow =
				IF(
					ISBLANK(_MarginDeltaPP),
					"&#8226;",
					IF(_MarginGood, "&#8593;", "&#8595;")
				)
			VAR _MarginRateFmt =
				IF(
					ISBLANK(_MarginRateYTD),
					"&mdash;",
					FORMAT(_MarginRateYTD, "0.0%")
				)
			VAR _GrossMarginFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_GrossMarginYTD), "&mdash;",
					ABS(_GrossMarginYTD) >= 1000000000, FORMAT(_GrossMarginYTD / 1000000000, "$0.0B"),
					ABS(_GrossMarginYTD) >= 1000000, FORMAT(_GrossMarginYTD / 1000000, "$0.0M"),
					ABS(_GrossMarginYTD) >= 1000, FORMAT(_GrossMarginYTD / 1000, "$0.0K"),
					FORMAT(_GrossMarginYTD, "$#,0")
				)
			VAR _MarginDeltaFmt =
				IF(
					ISBLANK(_MarginDeltaPP),
					"&mdash;",
					FORMAT(ABS(_MarginDeltaPP), "0.0") & " pp"
				)
			
			VAR _OrdersYTD = [# Orders YTD]
			VAR _OrdersYoY = [% Orders YoY YTD]
			VAR _UnitsYTD = [# Units YTD]
			VAR _AOVYTD = [$ Avg Order Value YTD]
			VAR _OrdersGood = COALESCE(_OrdersYoY, 0) >= 0
			VAR _OrdersColor =
				SWITCH(
					TRUE(),
					ISBLANK(_OrdersYoY), "#B3C7D9",
					_OrdersGood, "#3DBA7E",
					"#F87171"
				)
			VAR _OrdersPill =
				SWITCH(
					TRUE(),
					ISBLANK(_OrdersYoY), "#183A57",
					_OrdersGood, "#123F35",
					"#4A202A"
				)
			VAR _OrdersArrow =
				IF(
					ISBLANK(_OrdersYoY),
					"&#8226;",
					IF(_OrdersGood, "&#8593;", "&#8595;")
				)
			VAR _OrdersYTDFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_OrdersYTD), "&mdash;",
					ABS(_OrdersYTD) >= 1000000, FORMAT(_OrdersYTD / 1000000, "0.0M"),
					ABS(_OrdersYTD) >= 1000, FORMAT(_OrdersYTD / 1000, "0.0K"),
					FORMAT(_OrdersYTD, "#,0")
				)
			VAR _OrdersYoYFmt =
				IF(
					ISBLANK(_OrdersYoY),
					"&mdash;",
					FORMAT(ABS(_OrdersYoY), "0.0%")
				)
			VAR _UnitsYTDFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_UnitsYTD), "&mdash;",
					ABS(_UnitsYTD) >= 1000000, FORMAT(_UnitsYTD / 1000000, "0.0M"),
					ABS(_UnitsYTD) >= 1000, FORMAT(_UnitsYTD / 1000, "0.0K"),
					FORMAT(_UnitsYTD, "#,0")
				)
			VAR _AOVYTDFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_AOVYTD), "&mdash;",
					ABS(_AOVYTD) >= 1000000, FORMAT(_AOVYTD / 1000000, "$0.0M"),
					ABS(_AOVYTD) >= 1000, FORMAT(_AOVYTD / 1000, "$0.0K"),
					FORMAT(_AOVYTD, "$#,0")
				)
			
			RETURN
				"<style>
				.trend-kpi-wrap{
					display:grid;
					grid-template-columns:repeat(3,minmax(0,1fr));
					gap:12px;
					width:100%;
					height:100%;
					padding:3px;
					box-sizing:border-box;
					font-family:'Segoe UI',Arial,sans-serif;
				}
				.trend-kpi{
					background:#0E2841;
					border:1px solid #29445F;
					border-left:5px solid #C8A84B;
					border-radius:8px;
					padding:9px 13px;
					display:flex;
					flex-direction:column;
					justify-content:space-between;
					min-width:0;
					overflow:hidden;
					box-sizing:border-box;
				}
				.trend-label{
					color:#B3C7D9;
					font-size:9px;
					font-weight:700;
					letter-spacing:1.1px;
					line-height:1;
					text-transform:uppercase;
					white-space:nowrap;
				}
				.trend-value{
					color:#FFFFFF;
					font-size:25px;
					font-weight:700;
					line-height:1;
					margin:4px 0;
					white-space:nowrap;
				}
				.trend-footer{
					display:flex;
					align-items:center;
					justify-content:space-between;
					gap:7px;
					min-width:0;
				}
				.trend-context{
					color:#7F96AA;
					font-size:9px;
					line-height:1;
					white-space:nowrap;
					overflow:hidden;
					text-overflow:ellipsis;
				}
				.trend-pill{
					font-size:9px;
					font-weight:700;
					line-height:1;
					padding:3px 7px;
					border-radius:99px;
					white-space:nowrap;
				}
				</style>
				<div class='trend-kpi-wrap'>
					<div class='trend-kpi'>
						<div class='trend-label'>Revenue Pace</div>
						<div class='trend-value'>" & _RevenueYTDFmt & "</div>
						<div class='trend-footer'>
							<span class='trend-context'>vs PY YTD: " & _RevenuePYYTDFmt & "</span>
							<span class='trend-pill' style='color:" & _RevenueColor & ";background:" & _RevenuePill & ";'>" & _RevenueArrow & " " & _RevenueYoYFmt & " YoY</span>
						</div>
					</div>
					<div class='trend-kpi'>
						<div class='trend-label'>Profit Quality</div>
						<div class='trend-value'>" & _MarginRateFmt & "</div>
						<div class='trend-footer'>
							<span class='trend-context'>" & _GrossMarginFmt & " gross margin YTD</span>
							<span class='trend-pill' style='color:" & _MarginColor & ";background:" & _MarginPill & ";'>" & _MarginArrow & " " & _MarginDeltaFmt & " vs PY</span>
						</div>
					</div>
					<div class='trend-kpi'>
						<div class='trend-label'>Commercial Activity</div>
						<div class='trend-value'>" & _OrdersYTDFmt & " orders</div>
						<div class='trend-footer'>
							<span class='trend-context'>" & _UnitsYTDFmt & " units &middot; " & _AOVYTDFmt & " AOV</span>
							<span class='trend-pill' style='color:" & _OrdersColor & ";background:" & _OrdersPill & ";'>" & _OrdersArrow & " " & _OrdersYoYFmt & " YoY</span>
						</div>
					</div>
				</div>"
		displayFolder: 0_Custom_Visuals
		lineageTag: 94b95f13-af05-42f4-bc00-43042e925785

