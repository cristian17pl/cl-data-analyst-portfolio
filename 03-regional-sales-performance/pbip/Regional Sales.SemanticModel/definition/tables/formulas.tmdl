	measure 'REF Target Attainment Background Color' =
			VAR _Attainment = [% Target Attainment]
			RETURN
				SWITCH(
					TRUE(),
					ISBLANK(_Attainment), "#0E2841",
					_Attainment >= 1, "#3DBA7E",
					_Attainment >= 0.9, "#E8A33D",
					"#E63535"
				)
		displayFolder: 7_Text Cards
		lineageTag: 12a59daa-4db7-44ba-8965-28152cb28ef1

	measure 'REF Target Variance Font Color' =
			VAR _Variance = [$ Variance to Target]
			RETURN
				SWITCH(
					TRUE(),
					ISBLANK(_Variance), "#FFFFFF",
					_Variance < 0, "#FF3131",
					_Variance > 0, "#3DBA7E",
					"#FFFFFF"
				)
		displayFolder: 7_Text Cards
		lineageTag: 15156b4d-2d56-4c11-8f40-792c25bdce35

	measure 'VIS HTML Target KPI Cards' =
			VAR _Revenue = [$ Revenue in Target Period]
			VAR _Target = [$ Target Revenue]
			VAR _Variance = [$ Variance to Target]
			VAR _Attainment = [% Target Attainment]
			VAR _AttainmentDeltaPP = 100 * (_Attainment - 1)
			VAR _RegionsOnTarget = [# Regions On Target]
			VAR _RegionsWithTarget = [# Regions With Target]
			VAR _RegionsBelowTarget = [# Regions Below Target]
			VAR _RegionCoverage = [% Regions On Target]
			
			VAR _PlanGood = COALESCE(_Variance, 0) >= 0
			VAR _PlanColor = IF(_PlanGood, "#3DBA7E", "#F87171")
			VAR _PlanPill = IF(_PlanGood, "#123F35", "#4A202A")
			VAR _PlanLabel = IF(_PlanGood, "above plan", "below plan")
			VAR _CoverageGood = COALESCE(_RegionsBelowTarget, 0) = 0
			VAR _CoverageColor = IF(_CoverageGood, "#3DBA7E", "#F87171")
			VAR _CoveragePill = IF(_CoverageGood, "#123F35", "#4A202A")
			
			VAR _RevenueFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_Revenue), "&mdash;",
					ABS(_Revenue) >= 1000000000, FORMAT(_Revenue / 1000000000, "$0.0B"),
					ABS(_Revenue) >= 1000000, FORMAT(_Revenue / 1000000, "$0.0M"),
					ABS(_Revenue) >= 1000, FORMAT(_Revenue / 1000, "$0.0K"),
					FORMAT(_Revenue, "$#,0")
				)
			VAR _TargetFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_Target), "&mdash;",
					ABS(_Target) >= 1000000000, FORMAT(_Target / 1000000000, "$0.0B"),
					ABS(_Target) >= 1000000, FORMAT(_Target / 1000000, "$0.0M"),
					ABS(_Target) >= 1000, FORMAT(_Target / 1000, "$0.0K"),
					FORMAT(_Target, "$#,0")
				)
			VAR _VarianceFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_Variance), "&mdash;",
					ABS(_Variance) >= 1000000000, FORMAT(ABS(_Variance) / 1000000000, "$0.0B"),
					ABS(_Variance) >= 1000000, FORMAT(ABS(_Variance) / 1000000, "$0.0M"),
					ABS(_Variance) >= 1000, FORMAT(ABS(_Variance) / 1000, "$0.0K"),
					FORMAT(ABS(_Variance), "$#,0")
				)
			VAR _AttainmentFmt = IF(ISBLANK(_Attainment), "&mdash;", FORMAT(_Attainment, "0.0%"))
			VAR _AttainmentDeltaFmt = IF(ISBLANK(_AttainmentDeltaPP), "&mdash;", FORMAT(ABS(_AttainmentDeltaPP), "0.0") & " pp")
			VAR _RegionCountFmt =
				IF(
					ISBLANK(_RegionsWithTarget) || _RegionsWithTarget = 0,
					"&mdash;",
					FORMAT(_RegionsOnTarget, "#,0") & " of " & FORMAT(_RegionsWithTarget, "#,0")
				)
			VAR _RegionCoverageFmt = IF(ISBLANK(_RegionCoverage), "&mdash;", FORMAT(_RegionCoverage, "0.0%"))
			VAR _RegionsBelowFmt = FORMAT(COALESCE(_RegionsBelowTarget, 0), "#,0")
			
			RETURN
				"<style>
				.target-kpi-wrap{
					display:grid;
					grid-template-columns:repeat(3,minmax(0,1fr));
					gap:12px;
					width:100%;
					height:100%;
					padding:3px;
					box-sizing:border-box;
					font-family:'Segoe UI',Arial,sans-serif;
				}
				.target-kpi{
					background:#0E2841;
					border:1px solid #29445F;
					border-left:5px solid #C8A84B;
					border-radius:8px;
					padding:9px 13px;
					display:flex;
					flex-direction:column;
					justify-content:space-between;
					min-width:0;
					overflow:hidden;
					box-sizing:border-box;
				}
				.target-label{
					color:#B3C7D9;
					font-size:9px;
					font-weight:700;
					letter-spacing:1.1px;
					line-height:1;
					text-transform:uppercase;
					white-space:nowrap;
				}
				.target-value{
					color:#FFFFFF;
					font-size:25px;
					font-weight:700;
					line-height:1;
					margin:4px 0;
					white-space:nowrap;
				}
				.target-footer{
					display:flex;
					align-items:center;
					justify-content:space-between;
					gap:7px;
					min-width:0;
				}
				.target-context{
					color:#7F96AA;
					font-size:9px;
					line-height:1;
					white-space:nowrap;
					overflow:hidden;
					text-overflow:ellipsis;
				}
				.target-pill{
					font-size:9px;
					font-weight:700;
					line-height:1;
					padding:3px 7px;
					border-radius:99px;
					white-space:nowrap;
				}
				</style>
				<div class='target-kpi-wrap'>
					<div class='target-kpi'>
						<div class='target-label'>Revenue vs Plan</div>
						<div class='target-value'>" & _RevenueFmt & "</div>
						<div class='target-footer'>
							<span class='target-context'>Target " & _TargetFmt & "</span>
							<span class='target-pill' style='color:" & _PlanColor & ";background:" & _PlanPill & ";'>" & _VarianceFmt & " " & _PlanLabel & "</span>
						</div>
					</div>
					<div class='target-kpi'>
						<div class='target-label'>Plan Attainment</div>
						<div class='target-value'>" & _AttainmentFmt & "</div>
						<div class='target-footer'>
							<span class='target-context'>Threshold 100%</span>
							<span class='target-pill' style='color:" & _PlanColor & ";background:" & _PlanPill & ";'>" & _AttainmentDeltaFmt & " " & _PlanLabel & "</span>
						</div>
					</div>
					<div class='target-kpi'>
						<div class='target-label'>Regional Coverage</div>
						<div class='target-value'>" & _RegionCountFmt & " regions</div>
						<div class='target-footer'>
							<span class='target-context'>" & _RegionCoverageFmt & " on target</span>
							<span class='target-pill' style='color:" & _CoverageColor & ";background:" & _CoveragePill & ";'>" & _RegionsBelowFmt & " below target</span>
						</div>
					</div>
				</div>"
		displayFolder: 0_Custom_Visuals
		lineageTag: 45339923-cd51-425b-bde6-afce86cc599b

	measure '$ Revenue Top 15 Product' = IF([# Product Rank by Revenue] <= 15, [$ Total Revenue])
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: 6_Rankings\$
		lineageTag: 40e12ef6-1e58-4ccc-a694-4aaef89993cd

	measure '% Margin Rate Top 15 Product' = IF([# Product Rank by Revenue] <= 15, [% Margin Rate])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 6_Rankings\%
		lineageTag: 54fc390b-8ab7-46e0-a2f2-7480dd86d40c

	measure '# Units Top 15 Product' = IF([# Product Rank by Revenue] <= 15, [# Units Sold])
		formatString: #,0
		displayFolder: 6_Rankings\#
