	measure '% Reseller Revenue Share' =
			DIVIDE(
				[$ Revenue Reseller],
				CALCULATE(
					[$ Total Revenue],
					REMOVEFILTERS(dim_channel[Channel])
				)
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 5_Channel\%
		lineageTag: 0b174087-fc10-450e-85b7-46165817b1be

	measure 'VIS HTML Channel KPI Cards' =
			VAR _OnlineRevenue = [$ Revenue Online]
			VAR _OnlineShare = [% Online Revenue Share]
			VAR _OnlineMarginRate = [% Margin Rate Online]
			VAR _OnlineGrossMargin = [$ Gross Margin Online]
			VAR _OnlineAOV = [$ Avg Order Value Online]
			
			VAR _ResellerRevenue = [$ Revenue Reseller]
			VAR _ResellerShare = [% Reseller Revenue Share]
			VAR _ResellerMarginRate = [% Margin Rate Reseller]
			VAR _ResellerGrossMargin = [$ Gross Margin Reseller]
			VAR _ResellerAOV = [$ Avg Order Value Reseller]
			
			VAR _RevenueMultiple = DIVIDE(_ResellerRevenue, _OnlineRevenue)
			VAR _MarginGapPP = 100 * (_OnlineMarginRate - _ResellerMarginRate)
			VAR _GrossMarginGap = _OnlineGrossMargin - _ResellerGrossMargin
			
			VAR _OnlineRevenueFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_OnlineRevenue), "&mdash;",
					ABS(_OnlineRevenue) >= 1000000000, FORMAT(_OnlineRevenue / 1000000000, "$0.0B"),
					ABS(_OnlineRevenue) >= 1000000, FORMAT(_OnlineRevenue / 1000000, "$0.0M"),
					ABS(_OnlineRevenue) >= 1000, FORMAT(_OnlineRevenue / 1000, "$0.0K"),
					FORMAT(_OnlineRevenue, "$#,0")
				)
			VAR _OnlineShareFmt = IF(ISBLANK(_OnlineShare), "&mdash;", FORMAT(_OnlineShare, "0.0%"))
			VAR _OnlineMarginRateFmt = IF(ISBLANK(_OnlineMarginRate), "&mdash;", FORMAT(_OnlineMarginRate, "0.0%"))
			VAR _OnlineGrossMarginFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_OnlineGrossMargin), "&mdash;",
					ABS(_OnlineGrossMargin) >= 1000000000, FORMAT(_OnlineGrossMargin / 1000000000, "$0.0B;-$0.0B"),
					ABS(_OnlineGrossMargin) >= 1000000, FORMAT(_OnlineGrossMargin / 1000000, "$0.0M;-$0.0M"),
					ABS(_OnlineGrossMargin) >= 1000, FORMAT(_OnlineGrossMargin / 1000, "$0.0K;-$0.0K"),
					FORMAT(_OnlineGrossMargin, "$#,0;-$#,0")
				)
			VAR _OnlineAOVFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_OnlineAOV), "&mdash;",
					ABS(_OnlineAOV) >= 1000000, FORMAT(_OnlineAOV / 1000000, "$0.0M"),
					ABS(_OnlineAOV) >= 1000, FORMAT(_OnlineAOV / 1000, "$0.0K"),
					FORMAT(_OnlineAOV, "$#,0")
				)
			
			VAR _ResellerRevenueFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_ResellerRevenue), "&mdash;",
					ABS(_ResellerRevenue) >= 1000000000, FORMAT(_ResellerRevenue / 1000000000, "$0.0B"),
					ABS(_ResellerRevenue) >= 1000000, FORMAT(_ResellerRevenue / 1000000, "$0.0M"),
					ABS(_ResellerRevenue) >= 1000, FORMAT(_ResellerRevenue / 1000, "$0.0K"),
					FORMAT(_ResellerRevenue, "$#,0")
				)
			VAR _ResellerShareFmt = IF(ISBLANK(_ResellerShare), "&mdash;", FORMAT(_ResellerShare, "0.0%"))
			VAR _ResellerMarginRateFmt = IF(ISBLANK(_ResellerMarginRate), "&mdash;", FORMAT(_ResellerMarginRate, "0.0%"))
			VAR _ResellerGrossMarginFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_ResellerGrossMargin), "&mdash;",
					ABS(_ResellerGrossMargin) >= 1000000000, FORMAT(_ResellerGrossMargin / 1000000000, "$0.0B;-$0.0B"),
					ABS(_ResellerGrossMargin) >= 1000000, FORMAT(_ResellerGrossMargin / 1000000, "$0.0M;-$0.0M"),
					ABS(_ResellerGrossMargin) >= 1000, FORMAT(_ResellerGrossMargin / 1000, "$0.0K;-$0.0K"),
					FORMAT(_ResellerGrossMargin, "$#,0;-$#,0")
				)
			VAR _ResellerAOVFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_ResellerAOV), "&mdash;",
					ABS(_ResellerAOV) >= 1000000, FORMAT(_ResellerAOV / 1000000, "$0.0M"),
					ABS(_ResellerAOV) >= 1000, FORMAT(_ResellerAOV / 1000, "$0.0K"),
					FORMAT(_ResellerAOV, "$#,0")
				)
			
			VAR _RevenueMultipleFmt = IF(ISBLANK(_RevenueMultiple), "&mdash;", FORMAT(_RevenueMultiple, "0.0x"))
			VAR _MarginGapFmt = IF(ISBLANK(_MarginGapPP), "&mdash;", FORMAT(ABS(_MarginGapPP), "0.0") & " pp")
			VAR _GrossMarginGapFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_GrossMarginGap), "&mdash;",
					ABS(_GrossMarginGap) >= 1000000000, FORMAT(_GrossMarginGap / 1000000000, "$0.0B"),
					ABS(_GrossMarginGap) >= 1000000, FORMAT(_GrossMarginGap / 1000000, "$0.0M"),
					ABS(_GrossMarginGap) >= 1000, FORMAT(_GrossMarginGap / 1000, "$0.0K"),
					FORMAT(_GrossMarginGap, "$#,0")
				)
			
			VAR _OnlineGood = COALESCE(_OnlineMarginRate, 0) >= 0
			VAR _OnlineColor = IF(_OnlineGood, "#3DBA7E", "#F87171")
			VAR _OnlinePill = IF(_OnlineGood, "#123F35", "#4A202A")
			VAR _ResellerGood = COALESCE(_ResellerMarginRate, 0) >= 0
			VAR _ResellerColor = IF(_ResellerGood, "#3DBA7E", "#F87171")
			VAR _ResellerPill = IF(_ResellerGood, "#123F35", "#4A202A")
			
			RETURN
				"<style>
				.channel-kpi-wrap{
					display:grid;
					grid-template-columns:repeat(3,minmax(0,1fr));
					gap:12px;
					width:100%;
					height:100%;
					padding:3px;
					box-sizing:border-box;
					font-family:'Segoe UI',Arial,sans-serif;
				}
				.channel-kpi{
					background:#0E2841;
					border:1px solid #29445F;
					border-left:5px solid #C8A84B;
					border-radius:8px;
					padding:9px 13px;
					display:flex;
					flex-direction:column;
					justify-content:space-between;
					min-width:0;
					overflow:hidden;
					box-sizing:border-box;
				}
				.channel-label{
					display:flex;
					align-items:center;
					justify-content:space-between;
					gap:8px;
					color:#B3C7D9;
					font-size:9px;
					font-weight:700;
					letter-spacing:1.1px;
					line-height:1;
					text-transform:uppercase;
					white-space:nowrap;
				}
				.channel-tag{
					color:#7F96AA;
					font-size:8px;
					font-weight:600;
					letter-spacing:.5px;
				}
				.channel-value{
					color:#FFFFFF;
					font-size:25px;
					font-weight:700;
					line-height:1;
					margin:4px 0;
					white-space:nowrap;
				}
				.channel-footer{
					display:flex;
					align-items:center;
					justify-content:space-between;
					gap:7px;
					min-width:0;
				}
				.channel-context{
					color:#7F96AA;
					font-size:9px;
					line-height:1;
					white-space:nowrap;
					overflow:hidden;
					text-overflow:ellipsis;
				}
				.channel-pill{
					font-size:9px;
					font-weight:700;
					line-height:1;
					padding:3px 7px;
					border-radius:99px;
					white-space:nowrap;
				}
				</style>
				<div class='channel-kpi-wrap'>
					<div class='channel-kpi'>
						<div class='channel-label'><span>Online Engine</span><span class='channel-tag'>" & _OnlineShareFmt & " revenue share</span></div>
						<div class='channel-value'>" & _OnlineRevenueFmt & "</div>
						<div class='channel-footer'>
							<span class='channel-context'>" & _OnlineGrossMarginFmt & " gross margin - " & _OnlineAOVFmt & " AOV</span>
							<span class='channel-pill' style='color:" & _OnlineColor & ";background:" & _OnlinePill & ";'>" & _OnlineMarginRateFmt & " margin</span>
						</div>
					</div>
					<div class='channel-kpi'>
						<div class='channel-label'><span>Reseller Scale</span><span class='channel-tag'>" & _ResellerShareFmt & " revenue share</span></div>
						<div class='channel-value'>" & _ResellerRevenueFmt & "</div>
						<div class='channel-footer'>
							<span class='channel-context'>" & _ResellerGrossMarginFmt & " gross margin - " & _ResellerAOVFmt & " AOV</span>
							<span class='channel-pill' style='color:" & _ResellerColor & ";background:" & _ResellerPill & ";'>" & _ResellerMarginRateFmt & " margin</span>
						</div>
					</div>
					<div class='channel-kpi'>
						<div class='channel-label'><span>Channel Trade-off</span><span class='channel-tag'>Reseller vs Online</span></div>
						<div class='channel-value'>" & _RevenueMultipleFmt & " revenue</div>
						<div class='channel-footer'>
							<span class='channel-context'>" & _GrossMarginGapFmt & " gross-margin gap</span>
							<span class='channel-pill' style='color:#F87171;background:#4A202A;'>&#8595; " & _MarginGapFmt & " margin</span>
						</div>
					</div>
				</div>"
		displayFolder: 0_Custom_Visuals
		lineageTag: 2543e1c3-5e72-4b13-958a-d66319038e06

	measure '# Regions With Target' =
			COUNTROWS(
				FILTER(
					VALUES(dim_territory[Region]),
					NOT ISBLANK([$ Target Revenue])
				)
			)
		formatString: #,0
		displayFolder: 3_Targets\#
		lineageTag: 94c72070-c4b2-4f74-ae36-ab97a29a210a

	measure '# Regions Below Target' = MAX(0, [# Regions With Target] - [# Regions On Target])
