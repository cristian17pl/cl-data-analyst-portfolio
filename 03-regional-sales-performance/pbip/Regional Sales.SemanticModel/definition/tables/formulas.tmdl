	measure 'VIS HTML Territory KPI Cards' =
			VAR _Region = [REF Selected Region]
			VAR _Revenue = [$ Total Revenue]
			VAR _RevenuePY = [$ Revenue PY]
			VAR _RevenueYoY = [% Revenue YoY]
			VAR _Target = [$ Target Revenue]
			VAR _Variance = [$ Variance to Target]
			VAR _Attainment = [% Target Attainment]
			VAR _MarginRate = [% Margin Rate]
			VAR _GrossMargin = [$ Gross Margin]
			VAR _AOV = [$ Avg Order Value]
			
			VAR _RevenueGood = COALESCE(_RevenueYoY, 0) >= 0
			VAR _RevenueColor = IF(_RevenueGood, "#3DBA7E", "#F87171")
			VAR _RevenuePill = IF(_RevenueGood, "#123F35", "#4A202A")
			VAR _RevenueArrow = IF(ISBLANK(_RevenueYoY), "&#8226;", IF(_RevenueGood, "&#8593;", "&#8595;"))
			VAR _TargetGood = COALESCE(_Attainment, 0) >= 1
			VAR _TargetColor = IF(_TargetGood, "#3DBA7E", "#F87171")
			VAR _TargetPill = IF(_TargetGood, "#123F35", "#4A202A")
			VAR _TargetLabel = IF(_TargetGood, "above plan", "below plan")
			
			VAR _RevenueFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_Revenue), "&mdash;",
					ABS(_Revenue) >= 1000000000, FORMAT(_Revenue / 1000000000, "$0.0B"),
					ABS(_Revenue) >= 1000000, FORMAT(_Revenue / 1000000, "$0.0M"),
					ABS(_Revenue) >= 1000, FORMAT(_Revenue / 1000, "$0.0K"),
					FORMAT(_Revenue, "$#,0")
				)
			VAR _RevenuePYFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_RevenuePY), "&mdash;",
					ABS(_RevenuePY) >= 1000000000, FORMAT(_RevenuePY / 1000000000, "$0.0B"),
					ABS(_RevenuePY) >= 1000000, FORMAT(_RevenuePY / 1000000, "$0.0M"),
					ABS(_RevenuePY) >= 1000, FORMAT(_RevenuePY / 1000, "$0.0K"),
					FORMAT(_RevenuePY, "$#,0")
				)
			VAR _RevenueYoYFmt = IF(ISBLANK(_RevenueYoY), "&mdash;", FORMAT(ABS(_RevenueYoY), "0.0%"))
			VAR _TargetFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_Target), "&mdash;",
					ABS(_Target) >= 1000000000, FORMAT(_Target / 1000000000, "$0.0B"),
					ABS(_Target) >= 1000000, FORMAT(_Target / 1000000, "$0.0M"),
					ABS(_Target) >= 1000, FORMAT(_Target / 1000, "$0.0K"),
					FORMAT(_Target, "$#,0")
				)
			VAR _VarianceFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_Variance), "&mdash;",
					ABS(_Variance) >= 1000000000, FORMAT(ABS(_Variance) / 1000000000, "$0.0B"),
					ABS(_Variance) >= 1000000, FORMAT(ABS(_Variance) / 1000000, "$0.0M"),
					ABS(_Variance) >= 1000, FORMAT(ABS(_Variance) / 1000, "$0.0K"),
					FORMAT(ABS(_Variance), "$#,0")
				)
			VAR _AttainmentFmt = IF(ISBLANK(_Attainment), "&mdash;", FORMAT(_Attainment, "0.0%"))
			VAR _MarginRateFmt = IF(ISBLANK(_MarginRate), "&mdash;", FORMAT(_MarginRate, "0.0%"))
			VAR _GrossMarginFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_GrossMargin), "&mdash;",
					ABS(_GrossMargin) >= 1000000000, FORMAT(_GrossMargin / 1000000000, "$0.0B;-$0.0B"),
					ABS(_GrossMargin) >= 1000000, FORMAT(_GrossMargin / 1000000, "$0.0M;-$0.0M"),
					ABS(_GrossMargin) >= 1000, FORMAT(_GrossMargin / 1000, "$0.0K;-$0.0K"),
					FORMAT(_GrossMargin, "$#,0;-$#,0")
				)
			VAR _AOVFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_AOV), "&mdash;",
					ABS(_AOV) >= 1000000, FORMAT(_AOV / 1000000, "$0.0M"),
					ABS(_AOV) >= 1000, FORMAT(_AOV / 1000, "$0.0K"),
					FORMAT(_AOV, "$#,0")
				)
			
			RETURN
				"<style>
				.territory-kpi-wrap{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;width:100%;height:100%;padding:3px;box-sizing:border-box;font-family:'Segoe UI',Arial,sans-serif;}
				.territory-kpi{background:#0E2841;border:1px solid #29445F;border-left:5px solid #C8A84B;border-radius:8px;padding:9px 13px;display:flex;flex-direction:column;justify-content:space-between;min-width:0;overflow:hidden;box-sizing:border-box;}
				.territory-label{display:flex;align-items:center;justify-content:space-between;gap:8px;color:#B3C7D9;font-size:9px;font-weight:700;letter-spacing:1.1px;line-height:1;text-transform:uppercase;white-space:nowrap;}
				.territory-tag{color:#7F96AA;font-size:8px;font-weight:600;letter-spacing:.5px;overflow:hidden;text-overflow:ellipsis;}
				.territory-value{color:#FFFFFF;font-size:25px;font-weight:700;line-height:1;margin:4px 0;white-space:nowrap;}
				.territory-footer{display:flex;align-items:center;justify-content:space-between;gap:7px;min-width:0;}
				.territory-context{color:#7F96AA;font-size:9px;line-height:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
				.territory-pill{font-size:9px;font-weight:700;line-height:1;padding:3px 7px;border-radius:99px;white-space:nowrap;}
				</style>
				<div class='territory-kpi-wrap'>
					<div class='territory-kpi'>
						<div class='territory-label'><span>Territory Revenue</span><span class='territory-tag'>" & _Region & "</span></div>
						<div class='territory-value'>" & _RevenueFmt & "</div>
						<div class='territory-footer'><span class='territory-context'>vs PY " & _RevenuePYFmt & "</span><span class='territory-pill' style='color:" & _RevenueColor & ";background:" & _RevenuePill & ";'>" & _RevenueArrow & " " & _RevenueYoYFmt & " YoY</span></div>
					</div>
					<div class='territory-kpi'>
						<div class='territory-label'><span>Target Performance</span><span class='territory-tag'>Comparable period</span></div>
						<div class='territory-value'>" & _AttainmentFmt & "</div>
						<div class='territory-footer'><span class='territory-context'>Target " & _TargetFmt & "</span><span class='territory-pill' style='color:" & _TargetColor & ";background:" & _TargetPill & ";'>" & _VarianceFmt & " " & _TargetLabel & "</span></div>
					</div>
					<div class='territory-kpi'>
						<div class='territory-label'><span>Profitability</span><span class='territory-tag'>Margin quality</span></div>
						<div class='territory-value'>" & _MarginRateFmt & "</div>
						<div class='territory-footer'><span class='territory-context'>" & _GrossMarginFmt & " gross margin</span><span class='territory-pill' style='color:#B3C7D9;background:#183A57;'>" & _AOVFmt & " AOV</span></div>
					</div>
				</div>"
		displayFolder: 0_Custom_Visuals
		lineageTag: e16c7a78-4fd5-458f-bfc2-9a3617526c50

	measure '$ Revenue Last 12M Tooltip' =
			VAR _LastVisibleDate =
				CALCULATE(
					MAX(fact_sales[OrderDate]),
					ALLSELECTED(dim_date)
				)
			VAR _LastVisibleMonth =
				DATE(
					YEAR(_LastVisibleDate),
					MONTH(_LastVisibleDate),
					1
				)
			VAR _FirstVisibleMonth = EDATE(_LastVisibleMonth, -11)
			VAR _CurrentMonth = MAX(dim_date[MonthStart])
			RETURN
				IF(
					NOT ISBLANK(_LastVisibleDate)
						&& _CurrentMonth >= _FirstVisibleMonth
						&& _CurrentMonth <= _LastVisibleMonth,
					[$ Total Revenue]
				)
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: 4_Time Intelligence\$
		lineageTag: 7d2d24aa-9f12-4d55-aef1-f7600667ade3

	measure 'VIS HTML Tooltip KPI Cards' =
			VAR _Region = [REF Selected Region]
			VAR _Revenue = [$ Total Revenue]
			VAR _RevenuePY = [$ Revenue PY]
			VAR _RevenueYoY = [% Revenue YoY]
			VAR _YoYGood = COALESCE(_RevenueYoY, 0) >= 0
			VAR _YoYColor = IF(_YoYGood, "#3DBA7E", "#F87171")
			VAR _YoYPill = IF(_YoYGood, "#123F35", "#4A202A")
			VAR _YoYArrow = IF(ISBLANK(_RevenueYoY), "&#8226;", IF(_YoYGood, "&#8593;", "&#8595;"))
			VAR _RevenueFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_Revenue), "&mdash;",
					ABS(_Revenue) >= 1000000000, FORMAT(_Revenue / 1000000000, "$0.0B"),
					ABS(_Revenue) >= 1000000, FORMAT(_Revenue / 1000000, "$0.0M"),
					ABS(_Revenue) >= 1000, FORMAT(_Revenue / 1000, "$0.0K"),
					FORMAT(_Revenue, "$#,0")
				)
			VAR _RevenuePYFmt =
				SWITCH(
					TRUE(),
					ISBLANK(_RevenuePY), "&mdash;",
					ABS(_RevenuePY) >= 1000000000, FORMAT(_RevenuePY / 1000000000, "$0.0B"),
					ABS(_RevenuePY) >= 1000000, FORMAT(_RevenuePY / 1000000, "$0.0M"),
					ABS(_RevenuePY) >= 1000, FORMAT(_RevenuePY / 1000, "$0.0K"),
					FORMAT(_RevenuePY, "$#,0")
				)
			VAR _YoYFmt = IF(ISBLANK(_RevenueYoY), "&mdash;", FORMAT(ABS(_RevenueYoY), "0.0%"))
			RETURN
				"<style>
				.tooltip-kpi-wrap{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px;width:100%;height:100%;padding:1px;box-sizing:border-box;font-family:'Segoe UI',Arial,sans-serif;}
				.tooltip-kpi{background:#0E2841;border:1px solid #29445F;border-left:4px solid #C8A84B;border-radius:6px;padding:6px 9px;display:flex;flex-direction:column;justify-content:space-between;min-width:0;overflow:hidden;box-sizing:border-box;}
				.tooltip-label{display:flex;align-items:center;justify-content:space-between;gap:5px;color:#B3C7D9;font-size:7px;font-weight:700;letter-spacing:.8px;line-height:1;text-transform:uppercase;white-space:nowrap;}
				.tooltip-tag{color:#7F96AA;font-size:6px;letter-spacing:.3px;overflow:hidden;text-overflow:ellipsis;}
				.tooltip-value{color:#FFFFFF;font-size:20px;font-weight:700;line-height:1;margin:2px 0;white-space:nowrap;}
				.tooltip-footer{display:flex;align-items:center;justify-content:space-between;gap:4px;min-width:0;}
				.tooltip-context{color:#7F96AA;font-size:7px;line-height:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
				.tooltip-pill{font-size:7px;font-weight:700;line-height:1;padding:2px 5px;border-radius:99px;white-space:nowrap;}
				</style>
				<div class='tooltip-kpi-wrap'>
					<div class='tooltip-kpi'>
						<div class='tooltip-label'><span>Revenue</span><span class='tooltip-tag'>" & _Region & "</span></div>
						<div class='tooltip-value'>" & _RevenueFmt & "</div>
						<div class='tooltip-footer'><span class='tooltip-context'>vs PY " & _RevenuePYFmt & "</span></div>
					</div>
					<div class='tooltip-kpi'>
						<div class='tooltip-label'><span>YoY Change</span><span class='tooltip-tag'>vs prior year</span></div>
						<div class='tooltip-value' style='color:" & _YoYColor & ";'>" & _YoYFmt & "</div>
						<div class='tooltip-footer'><span class='tooltip-context'>Revenue momentum</span><span class='tooltip-pill' style='color:" & _YoYColor & ";background:" & _YoYPill & ";'>" & _YoYArrow & " YoY</span></div>
					</div>
				</div>"
		displayFolder: 0_Custom_Visuals
		lineageTag: eca9fc71-55e7-4752-8055-f5073dfcdbb0

	column Column
		isHidden
		formatString: 0
		lineageTag: e4d673c4-9f30-4c6e-8ac2-c93e2dfb0482
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Column]

		annotation SummarizationSetBy = Automatic

	partition formulas = calculated
		mode: import
		source = Row("Column", BLANK())

	annotation PBI_Id = f9d3e2615c48475d8b0a450e529112e9

